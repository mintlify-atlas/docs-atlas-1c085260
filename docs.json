{
  "$schema": "https://mintlify.com/docs.json",
  "name": "ElevenLabs Speech-to-Text API UI",
  "theme": "palm",
  "colors": {
    "primary": "#8B5CF6",
    "light": "#A78BFA",
    "dark": "#6D28D9"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/konhi/elevenlabs-speech-to-text-api-ui"
    }

  "keyFeatures": [
    "Audio/video file transcription using ElevenLabs Scribe API",
    "Speaker diarization with customizable speaker names",
    "Real-time transcript viewer with word-level synchronization",
    "Interactive audio playback with scrub bar control",
    "Support for multiple audio formats (MP3, WAV, OGG, M4A, AAC, WebM)",
    "Configurable transcription options (model selection, language, timestamps)",
    "Multi-channel audio support",
    "Audio event tagging and entity detection",
    "Character and word-level timestamp granularity"
  ],
  "publicApiSurface": [
    "SpeechToTextPlayground - Main playground component",
    "TranscriptionForm - Form for configuring transcription options",
    "TranscriptionResult - Component displaying transcription results",
    "TranscriptViewerContainer - Container for transcript viewer",
    "TranscriptViewerWords - Component rendering transcript words",
    "TranscriptViewerAudio - Audio player component",
    "TranscriptViewerPlayPauseButton - Play/pause control",
    "TranscriptViewerScrubBar - Audio scrub bar control",
    "useTranscriptViewer - Hook for transcript viewer state management",
    "convertToAlignment - Utility for converting transcript to alignment format",
    "getAudioTypeForFile - Utility for detecting audio file type"
  ]
}
